# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyright/
.coverage
.coverage.*
htmlcov/

# Virtual environments and local Python selection
.venv/
venv/
env/
ENV/
.python-version

# Packaging and build output
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# IDE and OS files
.idea/
.vscode/
.DS_Store
Thumbs.db
desktop.ini

# Local configuration and secrets
.env
.env.*
*.local

# Logs and temporary files
logs/
*.log
tmp/
temp/
.cache/
*.tmp
*.bak

# Runtime user data and generated output
projects/*
!projects/.gitkeep
exports/*
!exports/.gitkeep
reports/
output/
attachments/*
!attachments/.gitkeep
preview_cache/
thumbnails/

# Local databases and journals
*.sqlite-journal
*.db-journal
*.wal
*.shm

# User workspace settings
user_settings.json
workspace.json

# Qt generated cache
*.qmlc
*.jsc
